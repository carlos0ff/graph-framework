{
    "name": "carlos/graph-algorithms",
    "description": "Biblioteca de algoritmos e estruturas de grafos em PHP",
    "type": "project",
    "license": "MIT",

    "autoload": {
        "psr-4": {
            "Algorithms\\": "src/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Exercicios\\": "docs/exercicios/"
        }
    },

    "authors": [
        {
            "name": "Carlos Junior"
        }
    ],

    "require": {
        "php": "^8.2"
    },

    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },

    "scripts": {
        "test": "phpunit",
        "dump": "composer dump-autoload"
    }
}